APP_NAME=Qonhub AI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:18080
APP_PORT=18080
APP_TIMEZONE=Asia/Shanghai

SITE_NAME="Qonhub AI内容系统"
SITE_FULL_NAME="Qonhub AI内容生成系统"
ADMIN_BASE_PATH=geo_admin
GEOFLOW_PUBLIC_LOCALE=zh_CN

# --- 数据库（本地 PostgreSQL）---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=geo_flow
DB_USERNAME=geo_user
DB_PASSWORD=geo_password

SESSION_DRIVER=database
SESSION_LIFETIME=43200

# --- 队列和缓存（本地无需 Redis）---
QUEUE_CONNECTION=sync
CACHE_STORE=database
BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local

# --- AI 模型 API Key（必填）---
# 去 platform.deepseek.com 注册获取
# DEEPSEEK_API_KEY=sk-your-key-here

# --- 默认管理员 ---
GEOFLOW_ADMIN_USERNAME=admin
GEOFLOW_ADMIN_EMAIL=admin@example.com
GEOFLOW_ADMIN_PASSWORD=password
GEOFLOW_SEED_FRONTEND_DEMO=true
