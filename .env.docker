# ============================================
# Docker 容器化部署专用配置
# 用法：docker-compose --env-file .env.docker up -d
# 与本地 .env 完全独立，互不影响
# ============================================

APP_NAME=Qonhub AI
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=Asia/Shanghai

SITE_NAME="Qonhub AI内容系统"
SITE_FULL_NAME="Qonhub AI内容生成系统"
SITE_URL="${APP_URL}"
ADMIN_BASE_PATH=geo_admin
GEOFLOW_PUBLIC_LOCALE=zh_CN
GEOFLOW_ITEMS_PER_PAGE=12
GEOFLOW_ADMIN_ITEMS_PER_PAGE=20
GEOFLOW_TITLE_AI_KEYWORD_SAMPLE_LIMIT=10
GEOFLOW_UPLOAD_URL=/assets/images/
GEOFLOW_MAX_UPLOAD_BYTES=2097152
GEOFLOW_CACHE_ENABLED=true
GEOFLOW_CACHE_TTL=3600
GEOFLOW_MAX_LOGIN_ATTEMPTS=5
GEOFLOW_LOGIN_LOCKOUT_SECONDS=900
GEOFLOW_SESSION_TIMEOUT=2592000
GEOFLOW_CONTACT_INFO=""

# === Docker 特有：数据库用服务名 ===
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=geo_flow
DB_USERNAME=geo_user
DB_PASSWORD=geo_password

# === Docker 特有：用 Redis ===
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_STORE=redis
SESSION_DRIVER=redis

# === Docker 特有：用 Reverb ===
BROADCAST_CONNECTION=reverb
REVERB_HOST=reverb

# === AI 模型 Key（填你自己的） ===
# 从本地 .env 复制你的 AI API Key 到这里
# DEEPSEEK_API_KEY=sk-xxx

APP_LOCALE=zh_CN
APP_FAKER_LOCALE=en_US
LOG_CHANNEL=daily
LOG_LEVEL=debug

APP_PORT=18080
AUTO_OPTIMIZE=true
AUTO_FIX_STORAGE_PERMISSIONS=true
AUTO_MIGRATE=true
AUTO_INIT_ONCE=true
COMPOSER_ON_START=true

GEOFLOW_ADMIN_USERNAME=admin
GEOFLOW_ADMIN_PASSWORD=
GEOFLOW_SEED_FRONTEND_DEMO=false
